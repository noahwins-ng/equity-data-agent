#!/bin/sh
#
# Enforces commit message format: QNT-XX: type(scope): description
#
# Valid examples:
#   QNT-34: feat(shared): add Settings class
#   QNT-37: fix(db): handle migration edge case
#   QNT-41: refactor(dagster): extract rate limiter
#
# Valid types: feat, fix, refactor, test, docs, chore

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Allow merge commits and revert commits
if echo "$commit_msg" | grep -qE "^(Merge|Revert) "; then
    exit 0
fi

# Allow Co-Authored-By lines (check only the first line)
first_line=$(echo "$commit_msg" | head -1)

pattern="^QNT-[0-9]+: (feat|fix|refactor|test|docs|chore)\(.+\): .+"

if ! echo "$first_line" | grep -qE "$pattern"; then
    echo ""
    echo "ERROR: Invalid commit message format."
    echo ""
    echo "Expected: QNT-XX: type(scope): description"
    echo "Got:      $first_line"
    echo ""
    echo "Valid types: feat, fix, refactor, test, docs, chore"
    echo "Example:     QNT-34: feat(shared): add Settings class"
    echo ""
    exit 1
fi
