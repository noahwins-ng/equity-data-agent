# ─── Environment ──────────────────────────────────────────────
ENV=dev                             # dev | prod

# ─── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_HOST=localhost           # dev: localhost (via SSH tunnel), prod: clickhouse
CLICKHOUSE_PORT=8123

# ─── Qdrant Cloud ─────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ─── LiteLLM / LLM ───────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000  # dev: localhost:4000, prod: http://litellm:4000 (Docker service name)
OLLAMA_API_KEY=                     # Ollama Cloud API key (https://ollama.com — required for inference)
ANTHROPIC_API_KEY=                  # Claude API key — optional override (higher quality, paid)

# ─── Langfuse (Agent Tracing) ─────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Sentry (Error Tracking) ─────────────────────────────────
SENTRY_DSN=                         # FastAPI error tracking (free tier: 5k errors/mo)

# ─── Alerting (prod — QNT-101) ───────────────────────────────
# Discord webhook for container-state notifications (docker-events-notify.sh).
# Create at: Discord server → Server Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=
# Optional: external heartbeat URL pinged every 60s so an external monitor
# (e.g. BetterStack heartbeat monitor) alerts if the notifier itself dies.
HEARTBEAT_URL=

# ─── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000  # dev: localhost:8000, prod: https://your-domain.com

# ─── SSH Tunnel (dev only) ────────────────────────────────────
# Configure your ~/.ssh/config with a "hetzner" host alias:
#   Host hetzner
#     HostName <your-ip>
#     User root
#     IdentityFile ~/.ssh/id_ed25519
