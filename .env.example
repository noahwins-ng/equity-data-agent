# ─── Environment ──────────────────────────────────────────────
ENV=dev                             # dev | prod

# ─── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_HOST=localhost           # dev: localhost (via SSH tunnel), prod: clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=                # empty OK if your CH default user has no password

# ─── Qdrant Cloud ─────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ─── Agent → FastAPI (QNT-57) ─────────────────────────────────
# Base URL the LangGraph agent's tools hit to fetch reports / news search.
# Dev: http://localhost:8000 (matches dev-api). When the agent runs inside
# docker-compose, override with http://api:8000 for intra-compose networking.
API_BASE_URL=http://localhost:8000

# ─── LiteLLM / LLM (see ADR-011) ─────────────────────────────
# Note: docker --env-file keeps inline comments as part of the value.
# Leave these lines bare (no trailing "# ..." after the value).
LITELLM_BASE_URL=http://localhost:4000
# Default provider. Get a key at https://console.groq.com (free, email-only).
GROQ_API_KEY=
# Quality override. Get a key at https://aistudio.google.com/apikey (free, no card).
GEMINI_API_KEY=
# "groq" (default) | "gemini". Switches alias at runtime; no code changes.
EQUITY_AGENT_PROVIDER=groq

# ─── Langfuse (Agent Tracing) ─────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ─── Sentry (Error Tracking) ─────────────────────────────────
SENTRY_DSN=                         # FastAPI error tracking (free tier: 5k errors/mo)
# One-shot verification toggle for /api/v1/_debug/sentry. Default off so a
# scraper looping on the path can't burn the Sentry monthly quota; set to 1
# for a single deploy when verifying Sentry wiring end-to-end, then revert.
ENABLE_SENTRY_TEST=

# ─── Finnhub (News ingest, ADR-015) ──────────────────────────
# Per-ticker headlines + publisher + image via /company-news. Free tier is
# 60 RPM with 1y historical backfill (verified premium:null in docs JSON).
# Register at https://finnhub.io/register (email-only, no card).
FINNHUB_API_KEY=

# ─── Alerting (prod — QNT-101) ───────────────────────────────
# Discord webhook for container-state notifications (docker-events-notify.sh).
# Create at: Discord server → Server Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=
# Optional: external heartbeat URL pinged every 60s so an external monitor
# (e.g. Healthchecks.io free tier) alerts if the notifier itself dies.
HEARTBEAT_URL=

# ─── Frontend (Next.js) ───────────────────────────────────────
# Dev: http://localhost:8000 (FastAPI on the host).
# Prod: the cloudflared quick-tunnel hostname — extract from the cloudflared
# container logs after `docker compose --profile prod up -d`:
#   docker logs cloudflared 2>&1 | grep -oE 'https://[a-z0-9-]+\.trycloudflare\.com' | head -1
# Set the same value in the Vercel project's NEXT_PUBLIC_API_URL env var.
# When cloudflared restarts the URL rotates — see docs/guides/vercel-deploy.md.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── CORS (prod — QNT-161 + QNT-75) ──────────────────────────
# Origin allowlist for the FastAPI CORS middleware. Defaults in
# `shared/config.py` cover dev (localhost:3001); prod must add the Vercel
# production domain so the public chat panel can call the API. Both formats
# parse (config.py field_validator handles either):
#   CORS_ALLOWED_ORIGINS=https://<your-vercel-project>.vercel.app,http://localhost:3001
#   CORS_ALLOWED_ORIGINS=["https://<your-vercel-project>.vercel.app","http://localhost:3001"]
# Optional: pin a regex for Vercel preview deploys (one project only — leaked
# previews from unrelated projects must NOT drive traffic). Example:
#   CORS_ALLOWED_ORIGIN_REGEX=^https://<your-vercel-project>(-[a-z0-9-]+)?\.vercel\.app$
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=

# ─── Vercel Deploy Hook (QNT-168) ───────────────────────────
# Dagster POSTs this URL after each ingest cycle (3 cron schedules in
# packages/dagster-pipelines/.../vercel_deploy.py) so the statically rendered
# /ticker/[symbol] pages rebuild with fresh data. The hook URL itself is the
# auth -- no shared secret needed.
#
# Generate at: Vercel project → Settings → Git → Deploy Hooks → Create Hook.
# Leave blank in dev; the op skips with a warning when unset.
VERCEL_DEPLOY_HOOK_URL=

# ─── GitHub (MCP server) ─────────────────────────────────────
# Used by .mcp.json's github server (ghcr.io/github/github-mcp-server).
# Fetch with: gh auth token | pbcopy
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── SSH Tunnel (dev only) ────────────────────────────────────
# Configure your ~/.ssh/config with a "hetzner" host alias:
#   Host hetzner
#     HostName <your-ip>
#     User root
#     IdentityFile ~/.ssh/id_ed25519
