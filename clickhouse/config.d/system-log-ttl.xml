<?xml version="1.0"?>
<!--
  QNT-169: cap retention on noisy ClickHouse system log tables.

  Without TTL these tables grow unbounded; on the 17-day prod snapshot taken
  on 2026-05-06, system.text_log alone held 45.9M rows (1.41 GiB) and the
  background merges driven by that growth were the dominant cause of the
  monotonic CPU climb on clickhouse-1 (0.07 → 0.18 cores over 5.5h, peaking
  at 72% during a merge burst).

  Approach: 7-day retention via TTL DELETE, partitioned daily so each day's
  rows live in a single part that gets dropped cleanly when its TTL fires.
  ClickHouse default is monthly partitions, which keeps a full month's worth
  of rows in one part and forces row-level TTL deletes — daily partitions let
  the merger drop whole parts instead.

  Caveat: changing partition_by/ttl is a schema change, so on first restart
  ClickHouse renames the existing tables (text_log → text_log_0, etc.) and
  creates fresh ones with the new schema. The renamed tables retain the
  historical rows and are NOT covered by the new TTL — they must be dropped
  manually post-deploy. See docs/guides/ops-runbook.md "ClickHouse system-log
  creep (text_log/trace_log/metric_log/async_metric_log unbounded growth)".
-->
<clickhouse>
    <text_log>
        <database>system</database>
        <table>text_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </text_log>

    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </trace_log>

    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </metric_log>

    <asynchronous_metric_log>
        <database>system</database>
        <table>asynchronous_metric_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </asynchronous_metric_log>
</clickhouse>
